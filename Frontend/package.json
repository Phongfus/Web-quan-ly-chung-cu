{
  "name": "ant-design-pro",
  "version": "6.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",

  "scripts": {
    "build": "max build",
    "dev": "cross-env PORT=3000 UMI_ENV=dev UMI_USE_WEBPACK=1 max dev",

    "preview": "max preview --port 3000",

    "start": "npm run preview",

    "postinstall": "max setup",

    "lint": "npm run biome:lint && npm run tsc",
    "biome:lint": "npx @biomejs/biome lint",

    "test": "jest",
    "tsc": "tsc --noEmit"
  },

  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "3.1.2-0",
    "antd": "^6.2.2",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },

  "devDependencies": {
    "@ant-design/pro-cli": "^3.3.0",
    "@umijs/max": "^4.6.25",

    "@biomejs/biome": "^2.1.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.3",

    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.5",

    "husky": "^9.1.7"
  },

  "engines": {
    "node": "20.x"
  }
}